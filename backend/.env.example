# Backend ortam değişkenleri örneği — .env olarak kopyalayın

# Veritabanı - SQLite (geliştirme) veya PostgreSQL
DATABASE_URL=sqlite:///./carparking.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/carparking

# JWT - Production'da mutlaka değiştirin
SECRET_KEY=your-super-secret-key-change-in-production-32chars

# Kayıt + şifre sıfırlama: true ise API yanıtında debug_code döner (yalnızca geliştirme)
DEBUG_RETURN_SIGNUP_CODE=False

# Gmail SMTP (gerçek doğrulama maili için)
# 1) Google hesabınızda 2 adımlı doğrulamayı açın
# 2) https://myaccount.google.com/apppasswords adresinden "App password" üretin
# 3) Aşağıya o 16 haneli şifreyi yapıştırın (boşluksuz)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=CarParking
SMTP_USE_TLS=True

# QR redeem URL — telefonların açacağı backend adresi
# Boşsa request URL'inden çıkarılır (localhost olur, telefon erişemez).
# Sunum/test için bilgisayarınızın LAN IP'sini yazın:
#   PUBLIC_BASE_URL=http://192.168.1.50:8000
# Production: https://api.carparking.example.com
PUBLIC_BASE_URL=

# CV / YOLO
CV_DEVICE=auto
CV_WORKER_INTERVAL_SEC=3.0
